generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user")

  s3Credentials      S3Credential[]
  fileMetadata       FileMetadata[]
  fileExtensionStats UserFileExtensionStat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model S3Credential {
  id           String  @id @default(cuid())
  userId       String
  label        String
  provider     String  @default("HETZNER")
  endpoint     String
  region       String
  accessKeyEnc String  @db.Text
  secretKeyEnc String  @db.Text
  ivAccessKey  String
  ivSecretKey  String
  isDefault    Boolean @default(false)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileMetadata FileMetadata[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model FileMetadata {
  id           String   @id @default(cuid())
  userId       String
  credentialId String
  bucket       String
  key          String
  extension    String   @default("")
  size         BigInt
  lastModified DateTime
  isFolder     Boolean  @default(false)

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  credential S3Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@unique([credentialId, bucket, key])
  @@index([userId])
  @@index([credentialId, bucket])
  @@index([userId, extension])
}

model UserFileExtensionStat {
  id        String   @id @default(cuid())
  userId    String
  extension String
  fileCount Int      @default(0)
  totalSize BigInt   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, extension])
  @@index([userId])
}

model Task {
  id           String    @id @default(cuid())
  type         String
  title        String
  status       String    @default("pending")
  payload      Json
  progress     Json?
  error        String?
  isRecurring  Boolean   @default(false)
  scheduleCron String?
  nextRunAt    DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, nextRunAt])
  @@index([type])
}

model Backup {
  id        String   @id @default(cuid())
  key       String   @unique
  sizeBytes BigInt   @default(0)
  status    String   @default("ok")
  error     String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}
